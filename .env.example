# ── Runtime environment variables (nginx) ─────────────────────────────────────
#
# These are set in the deployment environment (e.g. Dokploy → Environment tab)
# and are substituted into nginx.conf at container start-up via envsubst.
# They are NEVER baked into the JS bundle and NEVER visible in the browser.

# Internal Docker URL for the Mealie container.
# In Dokploy, this is typically the container name on the shared network:
#   http://<compose-app-name>-mealie-1:9000
# Example for the scottfamily.nz deployment:
#   http://scottfamilynz-mealie-cvtizz-mealie-1:9000
MEALIE_INTERNAL_URL=http://localhost:9000

# Long-lived API token from your Mealie profile.
# Generate one at: Mealie → (your profile) → Settings → API Tokens
MEALIE_API_TOKEN=

# ── Build-time environment variables (Vite) ───────────────────────────────────
#
# These are baked into the JS bundle by Vite at build time.
# In production (Dokploy), set them as Docker build args (not runtime env vars).
# Locally, set them in .env for pnpm dev.

# Public base URL of the Mealie instance (used for "View in Mealie" links)
VITE_PUBLIC_MEALIE_BASE_URL=https://mealie.scottfamily.nz

# PostHog project token (public — safe to expose in the bundle)
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=

# PostHog UI host (used for the toolbar/session recordings UI link)
VITE_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ── Development-only ───────────────────────────────────────────────────────────
#
# The Vite dev server proxies /api/* to MEALIE_INTERNAL_URL and injects the
# Authorization header using MEALIE_API_TOKEN (see vite.config.ts).
# Copy this file to .env and fill in the values for local development.
# Do NOT commit .env to git.
