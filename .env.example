# URL of the Mealie backend.
# The Vite dev server proxies all /api requests to this URL, so the app and
# Mealie share the same origin (localhost:3000) during development.
VITE_MEALIE_BASE_URL=http://localhost:9000

# Long-lived API token from your Mealie profile.
# Generate one at: Mealie → (your profile) → Settings → API Tokens
# This is baked into the JS bundle at build time — do not commit .env to git.
VITE_MEALIE_API_TOKEN=
